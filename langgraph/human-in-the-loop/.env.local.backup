# ========================================================
# Azure OpenAI 配置（必需）
# ========================================================
AZURE_OPENAI_ENDPOINT=https://openai-hu-swendencentral.openai.azure.com/
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
OPENAI_API_VERSION=2025-03-01-preview

# ========================================================
# 仅用于本地测试的环境变量（部署时会被忽略）
# ========================================================
# 注意：AGENT_PROJECT_NAME 是保留变量，部署时由平台自动注入
# 仅在本地需要 REST API 测试时取消注释
# AGENT_PROJECT_NAME=local-workspace@local-account
#APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000