# Agent with Skills — 本地开发环境变量
# 复制此文件为 .env 并填入实际值：cp .env.sample .env

# === 必需 ===
# Azure OpenAI endpoint（从下面选择一个可用的资源）
#   - https://openai-xzh-eus2.openai.azure.com/    (ai-test, 有 gpt-5.2)
#   - https://ai-foundry-eastus-svc.cognitiveservices.azure.com/ (ai-xzh-external, 有 gpt-5.2, gpt-5-chat)
AZURE_OPENAI_ENDPOINT=https://ai-foundry-eastus-svc.cognitiveservices.azure.com/

# 模型部署名称（必须与所选 endpoint 上已部署的模型匹配）
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5-chat

# === 可选 ===
# 要加载的 Skill 列表（不设置则加载 skills/ 目录下全部内置 Skill）
# AGENT_SKILLS=local:travel-advisor,local:code-reviewer

# 覆盖 Agent 基础指令
# AGENT_BASE_INSTRUCTIONS=你是一个有用的助手。

# Skill 指令 token 上限（默认 4000）
# AGENT_MAX_SKILL_TOKENS=4000

# 启用 Web 搜索工具
# ENABLE_WEB_SEARCH=true

# MCP 工具连接 ID
# AZURE_AI_PROJECT_TOOL_CONNECTION_ID=
